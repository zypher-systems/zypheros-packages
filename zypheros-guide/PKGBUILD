# Maintainer: Zypher <zypher@zyphersystems.com>

pkgname=zypheros-guide
pkgver=0.2.1
pkgrel=2
pkgdesc="The official ZypherOS documentation and terminal reader"
arch=('any')
url="https://git.zyphersystems.com"
license=('GPL')
depends=('neovim' 'bat')
source=('zypheros-guide.md')
sha256sums=('SKIP') # Using SKIP so you don't have to update checksums every time you edit the text

package() {
  # 1. Install the master Markdown file into the system directory
  install -Dm644 "${srcdir}/zypheros-guide.md" "${pkgdir}/usr/share/zypheros/guide.md"

  # 2. Generate the universal terminal command
  mkdir -p "${pkgdir}/usr/bin"
  cat <<'EOF' >"${pkgdir}/usr/bin/zypheros-guide"
#!/bin/bash
# Launches the official ZypherOS guide in Neovim (Read-Only mode)
nvim -R /usr/share/zypheros/guide.md
EOF

  # 3. Make the command executable
  chmod +x "${pkgdir}/usr/bin/zypheros-guide"

  # 4. Create the GUI Application Menu Shortcut for Okular
  mkdir -p "${pkgdir}/usr/share/applications"
  cat <<'EOF' >"${pkgdir}/usr/share/applications/zypheros-guide.desktop"
[Desktop Entry]
Type=Application
Name=ZypherOS Guide
Comment=The Official ZypherOS User Manual
Exec=okular /usr/share/zypheros/guide.md
Icon=system-help
Terminal=false
Categories=System;Documentation;Core;
EOF
}
